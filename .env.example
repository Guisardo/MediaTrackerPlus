# =============================================================================
# MediaTrackerPlus — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables are optional unless marked REQUIRED.
#
# Defaults shown are the application fallback values when a variable is unset.
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Application environment. Controls migration file extension and other
# environment-specific behaviour.
# Values: development | production | test
NODE_ENV=production

# TCP port the HTTP server listens on.
PORT=7481

# IP address the server binds to. Use 0.0.0.0 to listen on all interfaces
# (required when running inside Docker or behind a reverse proxy).
HOSTNAME=127.0.0.1

# System timezone used for scheduling notifications and date/time operations.
# Accepts any IANA timezone name (e.g. America/New_York, Europe/London, UTC).
# Defaults to the system timezone of the host when unset.
# TZ=UTC


# -----------------------------------------------------------------------------
# Storage paths
# -----------------------------------------------------------------------------
# Defaults to subdirectories inside ~/.mediatracker/ when unset.
# Override when running in Docker or when you need a custom data layout.

# Directory where media poster and backdrop images are stored.
# ASSETS_PATH=~/.mediatracker/img

# Directory where application log files are written.
# LOGS_PATH=~/.mediatracker/logs

# Path to the SQLite database file.
# Only used when DATABASE_CLIENT=better-sqlite3 (the default).
# DATABASE_PATH=~/.mediatracker/data.db


# -----------------------------------------------------------------------------
# Database — SQLite (default)
# -----------------------------------------------------------------------------
# SQLite requires no additional configuration beyond DATABASE_PATH above.
# The variables in this section are only needed when switching to PostgreSQL.

# Database driver to use.
# Values: better-sqlite3 (SQLite, default) | pg (PostgreSQL)
DATABASE_CLIENT=better-sqlite3


# -----------------------------------------------------------------------------
# Database — PostgreSQL (optional, set DATABASE_CLIENT=pg to enable)
# -----------------------------------------------------------------------------

# Full connection string. When set, takes precedence over the individual
# host/port/user/password/database variables below.
# DATABASE_URL=postgresql://user:password@localhost:5432/mediatracker

# Database server hostname.
# DATABASE_HOST=localhost

# Database server port.
# DATABASE_PORT=5432

# Authentication credentials.
# DATABASE_USER=mediatracker
# DATABASE_PASSWORD=changeme

# Name of the database/schema to connect to.
# DATABASE_DATABASE=mediatracker

# Enable SSL for the database connection.
# Any non-empty value enables SSL with rejectUnauthorized: false.
# DATABASE_SSL=true

# Override the database engine version reported to Knex.
# Useful when the server version differs from what the client library expects.
# DATABASE_VERSION=


# -----------------------------------------------------------------------------
# Localization
# -----------------------------------------------------------------------------

# Server-side UI language used for log messages and push notifications.
# Values: da | de | en | es | fr | ko | pt
# SERVER_LANG=en

# Language code sent to the TMDB API for movie and TV show metadata.
# Accepts ISO 639-1 codes supported by TMDB (e.g. en, de, fr, es, pt, ko).
# TMDB_LANG=en

# Country code used for Audible audiobook metadata requests.
# Values: au | ca | de | es | fr | in | it | jp | gb | us
# AUDIBLE_LANG=us


# -----------------------------------------------------------------------------
# External API credentials
# -----------------------------------------------------------------------------

# TMDB API key for movie and TV show metadata and upnext recommendations.
# A default shared key is embedded in the application. Override this only if
# you have your own TMDB API key (e.g. to avoid rate-limit sharing).
# Obtain a key at: https://www.themoviedb.org/settings/api
# TMDB_API_KEY=

# IGDB (via Twitch) credentials for video game metadata and upnext game
# recommendations. Required only if you want to search for or track games.
# Obtain credentials at: https://api.igdb.com (Twitch Developer Console).
# IGDB_CLIENT_ID=
# IGDB_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------

# Demo mode — when enabled, disables user registration and account deletion.
# Intended for public demo deployments. Any non-empty value enables it.
# DEMO=false


# -----------------------------------------------------------------------------
# Docker / container (set by the official image; override as needed)
# -----------------------------------------------------------------------------

# UID and GID the container process runs as. Adjust to match your host
# user so that volume-mounted files are owned correctly.
# PUID=1000
# PGID=1000
