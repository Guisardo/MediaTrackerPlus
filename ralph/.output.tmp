diaType: 'movie',\n  1380→        source: 'user',\n  1381→        slug: '601',\n  1382→        openlibraryId: 123456,\n  1383→      },\n  1384→      {\n  1385→        id: 602,\n  1386→        title: '602',\n  1387→        mediaType: 'tv',\n  1388→        source: 'user',\n  1389→        slug: '602',\n  1390→        openlibraryId: 123456,\n  1391→      },\n  1392→    ]);\n  1393→\n  1394→    await Database.knex('mediaItem').insert([\n  1395→      {\n  1396→        id: 701,\n  1397→        title: '701',\n  1398→        mediaType: 'movie',\n  1399→        source: 'user',\n  1400→        slug: '701',\n  1401→        audibleId: 123456,\n  1402→      },\n  1403→      {\n  1404→        id: 702,\n  1405→        title: '702',\n  1406→        mediaType: 'tv',\n  1407→        source: 'user',\n  1408→        slug: '702',\n  1409→        audibleId: 123456,\n  1410→      },\n  1411→    ]);\n  1412→\n  1413→    await Database.knex('mediaItem').insert([\n  1414→      {\n  1415→        id: 801,\n  1416→        title: '801',\n  1417→        mediaType: 'movie',\n  1418→        source: 'user',\n  1419→        slug: '801',\n  1420→        goodreadsId: 123456,\n  1421→      },\n  1422→      {\n  1423→        id: 802,\n  1424→        title: '802',\n  1425→        mediaType: 'tv',\n  1426→        source: 'user',\n  1427→        slug: '802',\n  1428→        goodreadsId: 123456,\n  1429→      },\n  1430→    ]);\n  1431→  });\n  1432→\n  1433→  test('20230422000000_updateListRanks', async () => {\n  1434→    const initialLists = await Database.knex('list');\n  1435→    const initialListItems = await Database.knex('listItem');\n  1436→\n  1437→    await Database.knex('listItem').delete();\n  1438→    await Database.knex('list').delete();\n  1439→    await Database.knex('list').insert([\n  1440→      {\n  1441→        id: 0,\n  1442→        rank: 0,\n  1443→        name: 'List',\n  1444→        slug: 'list',\n  1445→        privacy: 'private',\n  1446→        sortBy: 'rank',\n  1447→        sortOrder: 'asc',\n  1448→        createdAt: new Date().getTime(),\n  1449→        updatedAt: new Date().getTime(),\n  1450→        userId: InitialData.user.id,\n  1451→        isWatchlist: false,\n  1452→      },\n  1453→      {\n  1454→        id: 1,\n  1455→        rank: 1,\n  1456→        name: 'List 2',\n  1457→        slug: 'list-2',\n  1458→        privacy: 'private',\n  1459→        sortBy: 'rank',\n  1460→        sortOrder: 'asc',\n  1461→        createdAt: new Date().getTime(),\n  1462→        updatedAt: new Date().getTime(),\n  1463→        userId: InitialData.user.id,\n  1464→        isWatchlist: false,\n  1465→      },\n  1466→      {\n  1467→        id: 3,\n  1468→        rank: 3,\n  1469→        name: 'List 3',\n  1470→        slug: 'list-3',\n  1471→        privacy: 'private',\n  1472→        sortBy: 'rank',\n  1473→        sortOrder: 'asc',\n  1474→        createdAt: new Date().getTime(),\n  1475→        updatedAt: new Date().getTime(),\n  1476→        userId: InitialData.user.id,\n  1477→        isWatchlist: false,\n  1478→      },\n  1479→      {\n  1480→        id: 4,\n  1481→        rank: 4,\n  1482→        name: 'List 4',\n  1483→        slug: 'list-4',\n  1484→        privacy: 'private',\n  1485→        sortBy: 'rank',\n  1486→        sortOrder: 'asc',\n  1487→        createdAt: new Date().getTime(),\n  1488→        updatedAt: new Date().getTime(),\n  1489→        userId: InitialData.user.id,\n  1490→        isWatchlist: false,\n  1491→      },\n  1492→    ]);\n  1493→\n  1494→    await Database.knex.migrate.up({\n  1495→      name: `20230422000000_updateListRanks.${Config.MIGRATIONS_EXTENSION}`,\n  1496→      directory: Config.MIGRATIONS_DIRECTORY,\n  1497→    });\n  1498→\n  1499→    await Database.knex.migrate.down({\n  1500→      directory: Config.MIGRATIONS_DIRECTORY,\n  1501→    });\n  1502→\n  1503→    await Database.knex.migrate.up({\n  1504→      name: `20230422000000_updateListRanks.${Config.MIGRATIONS_EXTENSION}`,\n  1505→      directory: Config.MIGRATIONS_DIRECTORY,\n  1506→    });\n  1507→\n  1508→    const lists = await Database.knex('list')\n  1509→      .select('name', 'rank')\n  1510→      .where('userId', InitialData.user.id)\n  1511→      .orderBy('rank');\n  1512→\n  1513→    expect(lists).toEqual([\n  1514→      { name: 'List', rank: 0 },\n  1515→      { name: 'List 2', rank: 1 },\n  1516→      { name: 'List 3', rank: 2 },\n  1517→      { name: 'List 4', rank: 3 },\n  1518→    ]);\n  1519→\n  1520→    await Database.knex('listItem').delete();\n  1521→    await Database.knex('list').delete();\n  1522→    await Database.knex('list').insert(initialLists);\n  1523→    await Database.knex('listItem').insert(initialListItems);\n  1524→  });\n  1525→\n  1526→  test('20230501000000_progress', async () => {\n  1527→    const date = Date.now();\n  1528→\n  1529→    await Database.knex('seen').where('type', 'progress').delete();\n  1530→\n  1531→    await Database.knex('seen').insert([\n  1532→      {\n  1533→        mediaItemId: InitialData.mediaItem.id,\n  1534→        type: 'progress',\n  1535→        progress: 0.1,\n  1536→        date: date - 100,\n  1537→        userId: InitialData.user.id,\n  1538→      },\n  1539→      {\n  1540→        mediaItemId: InitialData.mediaItem.id,\n  1541→        type: 'progress',\n  1542→        progress: 0.2,\n  1543→        date: date - 90,\n  1544→        userId: InitialData.user.id,\n  1545→      },\n  1546→      {\n  1547→        mediaItemId: InitialData.mediaItem.id,\n  1548→        type: 'progress',\n  1549→        progress: 0.3,\n  1550→        date: date - 80,\n  1551→        userId: InitialData.user.id,\n  1552→      },\n  1553→      {\n  1554→        mediaItemId: InitialData.mediaItem.id,\n  1555→        type: 'progress',\n  1556→        progress: 0.4,\n  1557→        date: date - 70,\n  1558→        userId: InitialData.user.id,\n  1559→      },\n  1560→    ]);\n  1561→\n  1562→    await Database.knex.migrate.up({\n  1563→      name: `20230501000000_progress.${Config.MIGRATIONS_EXTENSION}`,\n  1564→      directory: Config.MIGRATIONS_DIRECTORY,\n  1565→    });\n  1566→\n  1567→    await Database.knex.migrate.down({\n  1568→      directory: Config.MIGRATIONS_DIRECTORY,\n  1569→    });\n  1570→\n  1571→    await Database.knex.migrate.up({\n  1572→      name: `20230501000000_progress.${Config.MIGRATIONS_EXTENSION}`,\n  1573→      directory: Config.MIGRATIONS_DIRECTORY,\n  1574→    });\n  1575→\n  1576→    const progress = await Database.knex('progress');\n  1577→\n  1578→    expect(progress.length).toBe(1);\n  1579→    expect(progress.at(0).mediaItemId).toBe(InitialData.mediaItem.id);\n  1580→    expect(progress.at(0).progress).toBe(0.4);\n  1581→    expect(progress.at(0).date).toBe(date - 70);\n  1582→    expect(progress.at(0).userId).toBe(InitialData.user.id);\n  1583→  });\n  1584→\n  1585→  test('20230511000000_dropRankInList', async () => {\n  1586→    const listId = 999;\n  1587→    const { count } = await Database.knex('list')\n  1588→      .where('userId', InitialData.user.id)\n  1589→      .count({ count: '*' })\n  1590→      .as('count')\n  1591→      .first();\n  1592→\n  1593→    await Database.knex('list').insert({\n  1594→      id: listId,\n  1595→      name: 'migration test',\n  1596→      slug: 'migration-test',\n  1597→      userId: InitialData.user.id,\n  1598→      sortBy: 'rank' as unknown as ListSortBy,\n  1599→      rank: count,\n  1600→      privacy: 'private',\n  1601→      sortOrder: 'asc',\n  1602→      createdAt: Date.now(),\n  1603→      updatedAt: Date.now(),\n  1604→      isWatchlist: false,\n  1605→    });\n  1606→\n  1607→    await Database.knex.migrate.up({\n  1608→      name: `20230511000000_dropRankInList.${Config.MIGRATIONS_EXTENSION}`,\n  1609→      directory: Config.MIGRATIONS_DIRECTORY,\n  1610→    });\n  1611→\n  1612→    await Database.knex.migrate.down({\n  1613→      directory: Config.MIGRATIONS_DIRECTORY,\n  1614→    });\n  1615→\n  1616→    expect(\n  1617→      await Database.knex('list')\n  1618→        .where('userId', InitialData.user.id)\n  1619→        .orderBy('id')\n  1620→        .select('rank')\n  1621→    ).toEqual(\n  1622→      new Array(count + 1).fill(null).map((_, index) => ({ rank: index }))\n  1623→    );\n  1624→\n  1625→    await Database.knex.migrate.up({\n  1626→      name: `20230511000000_dropRankInList.${Config.MIGRATIONS_EXTENSION}`,\n  1627→      directory: Config.MIGRATIONS_DIRECTORY,\n  1628→    });\n  1629→  });\n  1630→\n  1631→  test('20230512000001_dropSlugInList', async () => {\n  1632→    await Database.knex.migrate.up({\n  1633→      name: `20230512000001_dropSlugInList.${Config.MIGRATIONS_EXTENSION}`,\n  1634→      directory: Config.MIGRATIONS_DIRECTORY,\n  1635→    });\n  1636→\n  1637→    await Database.knex.migrate.down({\n  1638→      directory: Config.MIGRATIONS_DIRECTORY,\n  1639→    });\n  1640→\n  1641→    await Database.knex.migrate.up({\n  1642→      name: `20230512000001_dropSlugInList.${Config.MIGRATIONS_EXTENSION}`,\n  1643→      directory: Config.MIGRATIONS_DIRECTORY,\n  1644→    });\n  1645→  });\n  1646→\n  1647→  test('20230512000002_dropSlugInUser', async () => {\n  1648→    await Database.knex.migrate.up({\n  1649→      name: `20230512000002_dropSlugInUser.${Config.MIGRATIONS_EXTENSION}`,\n  1650→      directory: Config.MIGRATIONS_DIRECTORY,\n  1651→    });\n  1652→\n  1653→    await Database.knex.migrate.down({\n  1654→      directory: Config.MIGRATIONS_DIRECTORY,\n  1655→    });\n  1656→\n  1657→    await Database.knex.migrate.up({\n  1658→      name: `20230512000002_dropSlugInUser.${Config.MIGRATIONS_EXTENSION}`,\n  1659→      directory: Config.MIGRATIONS_DIRECTORY,\n  1660→    });\n  1661→  });\n  1662→\n  1663→  test('20230512000003_refactorConfigurationToJson', async () => {\n  1664→    const config = await Database.knex('configuration').first();\n  1665→\n  1666→    expect(config).toBeDefined();\n  1667→\n  1668→    delete config.id;\n  1669→\n  1670→    await Database.kn