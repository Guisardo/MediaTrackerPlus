{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_015C3uwrEqMChjGENHKrR5zf","type":"tool_result","content":"     1→import { milliseconds } from 'date-fns';\n     2→\n     3→import { Config } from 'src/config';\n     4→import { clearDatabase, randomNumericId } from '../__utils__/utils';\n     5→import { Data, InitialData } from '__tests__/__utils__/data';\n     6→import { Configuration } from 'src/entity/configuration';\n     7→import { MediaItemBase } from 'src/entity/mediaItem';\n     8→import { Database } from 'src/dbconfig';\n     9→import { randomSlugId, toSlug } from 'src/slug';\n    10→import { nanoid } from 'nanoid';\n    11→import { ListSortBy } from 'src/entity/list';\n    12→\n    13→describe('migrations', () => {\n    14→  beforeAll(async () => {\n    15→    Database.init();\n    16→    await Database.knex.migrate.rollback(\n    17→      {\n    18→        directory: Config.MIGRATIONS_DIRECTORY,\n    19→      },\n    20→      true\n    21→    );\n    22→\n    23→    await Database.knex.migrate.up({\n    24→      name: `20210818142342_init.${Config.MIGRATIONS_EXTENSION}`,\n    25→      directory: Config.MIGRATIONS_DIRECTORY,\n    26→    });\n    27→\n    28→    await Database.knex('user').insert(InitialData.user);\n    29→    await Database.knex('configuration').insert(InitialData.configuration);\n    30→    await Database.knex('accessToken').insert(InitialData.accessToken);\n    31→    await Database.knex('mediaItem').insert(InitialData.mediaItem);\n    32→    await Database.knex('season').insert(InitialData.season);\n    33→    await Database.knex('episode').insert(InitialData.episode);\n    34→    await Database.knex('seen').insert(InitialData.seen);\n    35→    await Database.knex('watchlist').insert(InitialData.watchlist);\n    36→    await Database.knex('userRating').insert(InitialData.userRating);\n    37→    await Database.knex('userRating').insert(InitialData.userRating2);\n    38→    await Database.knex('userRating').insert(InitialData.userRating3);\n    39→    await Database.knex('notificationsHistory').insert(\n    40→      InitialData.notificationsHistory\n    41→    );\n    42→    await Database.knex('notificationPlatformsCredentials').insert(\n    43→      InitialData.notificationPlatformsCredentials\n    44→    );\n    45→    await Database.knex('metadataProviderCredentials').insert(\n    46→      InitialData.metadataProviderCredentials\n    47→    );\n    48→    await Database.knex('metadataProviderCredentials').insert(\n    49→      InitialData.metadataProviderCredentials2\n    50→    );\n    51→  });\n    52→\n    53→  test('20220121025651_ratingColumnFloat', async () => {\n    54→    await Database.knex.migrate.up({\n    55→      name: `20220121025651_ratingColumnFloat.${Config.MIGRATIONS_EXTENSION}`,\n    56→      directory: Config.MIGRATIONS_DIRECTORY,\n    57→    });\n    58→\n    59→    await Database.knex.migrate.down({\n    60→      directory: Config.MIGRATIONS_DIRECTORY,\n    61→    });\n    62→\n    63→    await Database.knex.migrate.up({\n    64→      name: `20220121025651_ratingColumnFloat.${Config.MIGRATIONS_EXTENSION}`,\n    65→      directory: Config.MIGRATIONS_DIRECTORY,\n    66→    });\n    67→  });\n    68→\n    69→  test('20220122003141_bigIntToFloat', async () => {\n    70→    await Database.knex.migrate.up({\n    71→      name: `20220122003141_bigIntToFloat.${Config.MIGRATIONS_EXTENSION}`,\n    72→      directory: Config.MIGRATIONS_DIRECTORY,\n    73→    });\n    74→\n    75→    await Database.knex.migrate.down({\n    76→      directory: Config.MIGRATIONS_DIRECTORY,\n    77→    });\n    78→\n    79→    await Database.knex.migrate.up({\n    80→      name: `20220122003141_bigIntToFloat.${Config.MIGRATIONS_EXTENSION}`,\n    81→      directory: Config.MIGRATIONS_DIRECTORY,\n    82→    });\n    83→  });\n    84→\n    85→  test('20220127224112_configuration', async () => {\n    86→    await Database.knex.migrate.up({\n    87→      name: `20220127224112_configuration.${Config.MIGRATIONS_EXTENSION}`,\n    88→      directory: Config.MIGRATIONS_DIRECTORY,\n    89→    });\n    90→\n    91→    await Database.knex<Configuration>('configuration').update({\n    92→      audibleLang: 'us',\n    93→      serverLang: 'en',\n    94→      tmdbLang: 'en',\n    95→    });\n    96→\n    97→    await Database.knex.migrate.down({\n    98→      directory: Config.MIGRATIONS_DIRECTORY,\n    99→    });\n   100→\n   101→    await Database.knex.migrate.up({\n   102→      name: `20220127224112_configuration.${Config.MIGRATIONS_EXTENSION}`,\n   103→      directory: Config.MIGRATIONS_DIRECTORY,\n   104→    });\n   105→  });\n   106→\n   107→  test('20220202231058_image', async () => {\n   108→    await Database.knex.migrate.up({\n   109→      name: `20220202231058_image.${Config.MIGRATIONS_EXTENSION}`,\n   110→      directory: Config.MIGRATIONS_DIRECTORY,\n   111→    });\n   112→\n   113→    await Database.knex('image').insert({\n   114→      id: '1',\n   115→      mediaItemId: InitialData.mediaItem.id,\n   116→      type: 'poster',\n   117→    });\n   118→\n   119→    await Database.knex('image').insert({\n   120→      id: '2',\n   121→      mediaItemId: InitialData.season.tvShowId,\n   122→      seasonId: InitialData.season.id,\n   123→      type: 'backdrop',\n   124→    });\n   125→\n   126→    await Database.knex.migrate.down({\n   127→      directory: Config.MIGRATIONS_DIRECTORY,\n   128→    });\n   129→\n   130→    await Database.knex.migrate.up({\n   131→      name: `20220202231058_image.${Config.MIGRATIONS_EXTENSION}`,\n   132→      directory: Config.MIGRATIONS_DIRECTORY,\n   133→    });\n   134→  });\n   135→\n   136→  test('20220208203349_traktId_goodreadsId', async () => {\n   137→    await Database.knex.migrate.up({\n   138→      name: `20220208203349_traktId_goodreadsId.${Config.MIGRATIONS_EXTENSION}`,\n   139→      directory: Config.MIGRATIONS_DIRECTORY,\n   140→    });\n   141→\n   142→    await Database.knex<MediaItemBase>('mediaItem').insert({\n   143→      id: 999,\n   144→      title: 'title',\n   145→      source: 'user',\n   146→      traktId: 123456,\n   147→      goodreadsId: 987654,\n   148→    });\n   149→\n   150→    await Database.knex.migrate.down({\n   151→      directory: Config.MIGRATIONS_DIRECTORY,\n   152→    });\n   153→\n   154→    await Database.knex.migrate.up({\n   155→      name: `20220208203349_traktId_goodreadsId.${Config.MIGRATIONS_EXTENSION}`,\n   156→      directory: Config.MIGRATIONS_DIRECTORY,\n   157→    });\n   158→  });\n   159→\n   160→  test('20220208230635_numberOfPages', async () => {\n   161→    await Database.knex.migrate.up({\n   162→      name: `20220208230635_numberOfPages.${Config.MIGRATIONS_EXTENSION}`,\n   163→      directory: Config.MIGRATIONS_DIRECTORY,\n   164→    });\n   165→\n   166→    await Database.knex<MediaItemBase>('mediaItem').insert({\n   167→      id: 777,\n   168→      title: 'title',\n   169→      source: 'user',\n   170→      numberOfPages: 111,\n   171→    });\n   172→\n   173→    await Database.knex.migrate.down({\n   174→      directory: Config.MIGRATIONS_DIRECTORY,\n   175→    });\n   176→\n   177→    await Database.knex.migrate.up({\n   178→      name: `20220208230635_numberOfPages.${Config.MIGRATIONS_EXTENSION}`,\n   179→      directory: Config.MIGRATIONS_DIRECTORY,\n   180→    });\n   181→  });\n   182→\n   183→  test('20220208234441_watchlist', async () => {\n   184→    await Database.knex.migrate.up({\n   185→      name: `20220208234441_watchlist.${Config.MIGRATIONS_EXTENSION}`,\n   186→      directory: Config.MIGRATIONS_DIRECTORY,\n   187→    });\n   188→\n   189→    const watchlist = {\n   190→      id: 777,\n   191→      userId: 1,\n   192→      mediaItemId: 1,\n   193→      addedAt: new Date().getTime(),\n   194→    };\n   195→\n   196→    await Database.knex('watchlist').insert(watchlist);\n   197→\n   198→    expect(\n   199→      await Database.knex('watchlist').where('id', watchlist.id).first()\n   200→    ).toEqual(watchlist);\n   201→\n   202→    await Database.knex.migrate.down({\n   203→      directory: Config.MIGRATIONS_DIRECTORY,\n   204→    });\n   205→\n   206→    await Database.knex.migrate.up({\n   207→      name: `20220208234441_watchlist.${Config.MIGRATIONS_EXTENSION}`,\n   208→      directory: Config.MIGRATIONS_DIRECTORY,\n   209→    });\n   210→  });\n   211→\n   212→  test('20220209000937_seen', async () => {\n   213→    const mediaItem = {\n   214→      id: randomNumericId(),\n   215→      title: 'title',\n   216→      source: 'user',\n   217→      runtime: 121,\n   218→    };\n   219→\n   220→    const show = {\n   221→      id: randomNumericId(),\n   222→      title: 'title',\n   223→      source: 'user',\n   224→      runtime: 42,\n   225→    };\n   226→\n   227→    const season = {\n   228→      id: randomNumericId(),\n   229→      title: 'Season 1',\n   230→      isSpecialSeason: false,\n   231→      seasonNumber: 1,\n   232→      tvShowId: show.id,\n   233→      numberOfEpisodes: 1,\n   234→    };\n   235→\n   236→    const episodeWithRuntime = {\n   237→      id: randomNumericId(),\n   238→      title: 'Episode 1',\n   239→      seasonNumber: 1,\n   240→      episodeNumber: 1,\n   241→      isSpecialEpisode: false,\n   242→      runtime: 31,\n   243→      tvShowId: show.id,\n   244→      seasonId: season.id,\n   245→      seasonAndEpisodeNumber: 1001,\n   246→    };\n   247→\n   248→    const episodeWithoutRuntime = {\n   249→      id: randomNumericId(),\n   250→      title: 'Episode 2',\n   251→      seasonNumber: 1,\n   252→      episodeNumber: 2,\n   253→      isSpecialEpisode: false,\n   254→      tvShowId: show.id,\n   255→      seasonId: season.id,\n   256→      seasonAndEpisodeNumber: 1002,\n   257→    };\n   258→\n   259→    const seenMediaItem = {\n   260→      id: randomNumericId(),\n   261→      userId: 1,\n   262→      mediaItemId: mediaItem.id,\n   263→    };\n   264→\n   265→    const seenEpisodeWithRuntime = {\n   266→      id: randomNumericId(),\n   267→      userId: 1,\n   268→      mediaItemId: show.id,\n   269→      episodeId: episodeWithRuntime.id,\n   270→    };\n   271→\n   272→    const seenEpisodeWithoutRuntime = {\n   273→      id: randomNumericId(),\n   274→      userId: 1,\n   275→      mediaItemId: show.id,\n   276→      episodeId: episodeWithoutRuntime.id,\n   277→    };\n   278→\n   279→    await Database.knex('mediaItem').insert(mediaItem);\n   280→    await Database.knex('mediaItem').insert(show);\n   281→    await Database.knex('season').insert(season);\n   282→    await Database.knex('episode').insert(episodeWithRuntime);\n   283→    await Database.knex('episode').insert(episodeWithoutRuntime);\n   284→    await Database.knex('seen').insert(seenMediaItem);\n   285→    await Database.knex('seen').insert(seenEpisodeWithRuntime);\n   286→    await Database.knex('seen').insert(seenEpisodeWithoutRuntime);\n   287→\n   288→    await Database.knex.migrate.up({\n   289→      name: `20220209000937_seen.${Config.MIGRATIONS_EXTENSION}`,\n   290→      directory: Config.MIGRATIONS_DIRECTORY,\n   291→    });\n   292→\n   293→    expect(\n   294→      (\n   295→        await Database.knex('seen')\n   296→          .where('id', seenEpisodeWithRuntime.id)\n   297→          .first()\n   298→      ).duration\n   299→    ).toEqual(episodeWithRuntime.runtime * 60 * 1000);\n   300→\n   301→    expect(\n   302→      (\n   303→        await Database.knex('seen')\n   304→          .where('id', seenEpisodeWithoutRuntime.id)\n   305→          .first()\n   306→      ).duration\n   307→    ).toEqual(show.runtime * 60 * 1000);\n   308→\n   309→    expect(\n   310→      (await Database.knex('seen').where('id', seenMediaItem.id).first())\n   311→        .duration\n   312→    ).toEqual(mediaItem.runtime * 60 * 1000);\n   313→\n   314→    const seen = {\n   315→      id: randomNumericId(),\n   316→      userId: 1,\n   317→      mediaItemId: 1,\n   318→      duration: milliseconds({\n   319→        hours: 1,\n   320→        minutes: 10,\n   321→        seconds: 12,\n   322→      }),\n   323→      action: 'watched',\n   324→      date: new Date().getTime(),\n   325→      progress: 0.2,\n   326→    };\n   327→\n   328→    await Database.knex('seen').insert(seen);\n   329→\n   330→    await Database.knex.migrate.down({\n   331→      directory: Config.MIGRATIONS_DIRECTORY,\n   332→    });\n   333→\n   334→    await Database.knex.migrate.up({\n   335→      name: `20220209000937_seen.${Config.MIGRATIONS_EXTENSION}`,\n   336→      directory: Config.MIGRATIONS_DIRECTORY,\n   337→    });\n   338→\n   339→    await Database.knex('seen').where('id', seen.id).delete();\n   340→    await Database.knex('seen').insert(seen);\n   341→  });\n   342→\n   343→  test('20220209005700_list', async () => {\n   344→    await Database.knex.migrate.up({\n   345→      name: `20220209005700_list.${Config.MIGRATIONS_EXTENSION}`,\n   346→      directory: Config.MIGRATIONS_DIRECTORY,\n   347→    });\n   348→\n   349→    const list = {\n   350→      id: 1,\n   351→      name: 'list',\n   352→      createdAt: new Date().getTime(),\n   353→      updatedAt: new Date().getTime(),\n   354→      userId: 1,\n   355→      description: 'description',\n   356→      privacy: 'private',\n   357→    };\n   358→\n   359→    const listItem = {\n   360→      addedAt: new Date().getTime(),\n   361→      listId: 1,\n   362→      mediaItemId: 1,\n   363→    };\n   364→\n   365→    await Database.knex('list').insert(list);\n   366→    await Database.knex('listItem').insert(listItem);\n   367→\n   368→    await Database.knex.migrate.down({\n   369→      directory: Config.MIGRATIONS_DIRECTORY,\n   370→    });\n   371→\n   372→    await Database.knex.migrate.up({\n   373→      name: `20220209005700_list.${Config.MIGRATIONS_EXTENSION}`,\n   374→      directory: Config.MIGRATIONS_DIRECTORY,\n   375→    });\n   376→\n   377→    await Database.knex('list').insert(list);\n   378→    await Database.knex('listItem').insert(listItem);\n   379→  });\n   380→\n   381→  test('20220209014700_userPreferences', async () => {\n   382→    await Database.knex.migrate.up({\n   383→      name: `20220209014700_userPreferences.${Config.MIGRATIONS_EXTENSION}`,\n   384→      directory: Config.MIGRATIONS_DIRECTORY,\n   385→    });\n   386→\n   387→    const user = {\n   388→      id: randomNumericId(),\n   389→      name: 'name2',\n   390→      password: 'password',\n   391→      clientPreferences: {\n   392→        hideEpisodeTitleForUnseenEpisodes: true,\n   393→        hideOverviewForUnseenSeasons: true,\n   394→      },\n   395→    };\n   396→\n   397→    await Database.knex('user').insert(user);\n   398→\n   399→    await Database.knex.migrate.down({\n   400→      directory: Config.MIGRATIONS_DIRECTORY,\n   401→    });\n   402→\n   403→    await Database.knex.migrate.up({\n   404→      name: `20220209014700_userPreferences.${Config.MIGRATIONS_EXTENSION}`,\n   405→      directory: Config.MIGRATIONS_DIRECTORY,\n   406→    });\n   407→\n   408→    await Database.knex('user').where('id', user.id).delete();\n   409→    await Database.knex('user').insert(user);\n   410→  });\n   411→\n   412→  test('20220209034100_userPreferences', async () => {\n   413→    await Database.knex.migrate.up({\n   414→      name: `20220209034100_userPreferences.${Config.MIGRATIONS_EXTENSION}`,\n   415→      directory: Config.MIGRATIONS_DIRECTORY,\n   416→    });\n   417→\n   418→    const user = {\n   419→      id: randomNumericId(),\n   420→      name: 'name',\n   421→      password: 'password',\n   422→      hideEpisodeTitleForUnseenEpisodes: true,\n   423→      hideOverviewForUnseenSeasons: true,\n   424→    };\n   425→\n   426→    await Database.knex('user').insert(user);\n   427→\n   428→    await Database.knex.migrate.down({\n   429→      directory: Config.MIGRATIONS_DIRECTORY,\n   430→    });\n   431→\n   432→    await Database.knex.migrate.up({\n   433→      name: `20220209034100_userPreferences.${Config.MIGRATIONS_EXTENSION}`,\n   434→      directory: Config.MIGRATIONS_DIRECTORY,\n   435→    });\n   436→\n   437→    await Database.knex('user').where('id', user.id).delete();\n   438→    await Database.knex('user').insert(user);\n   439→  });\n   440→\n   441→  test('20220217012900_progress', async () => {\n   442→    const seen = {\n   443→      id: randomNumericId(),\n   444→      userId: InitialData.user.id,\n   445→      mediaItemId: InitialData.mediaItem.id,\n   446→      date: new Date().getTime(),\n   447→      action: 'started',\n   448→    };\n   449→\n   450→    const seen2 = {\n   451→      id: randomNumericId(),\n   452→      userId: InitialData.user.id,\n   453→      mediaItemId: InitialData.mediaItem.id,\n   454→      episodeId: InitialData.episode.id,\n   455→      date: new Date().getTime() - 10,\n   456→      action: 'started',\n   457→    };\n   458→\n   459→    await Database.knex('seen').insert(seen);\n   460→    await Database.knex('seen').insert(seen2);\n   461→\n   462→    await Database.knex.migrate.up({\n   463→      name: `20220217012900_progress.${Config.MIGRATIONS_EXTENSION}`,\n   464→      directory: Config.MIGRATIONS_DIRECTORY,\n   465→    });\n   466→\n   467→    const progress = await Database.knex('seen')\n   468→      .where('type', 'progress')\n   469→      .where('mediaItemId', seen.mediaItemId)\n   470→      .whereNull('episodeId')\n   471→      .first();\n   472→\n   473→    const progress2 = await Database.knex('seen')\n   474→      .where('type', 'progress')\n   475→      .where('mediaItemId', seen2.mediaItemId)\n   476→      .where('episodeId', seen2.episodeId)\n   477→      .first();\n   478→\n   479→    expect(progress).toMatchObject({\n   480→      userId: seen.userId,\n   481→      progress: 0,\n   482→      date: seen.date,\n   483→    });\n   484→\n   485→    expect(progress2).toMatchObject({\n   486→      userId: seen2.userId,\n   487→      progress: 0,\n   488→      date: seen2.date,\n   489→    });\n   490→\n   491→    await Database.knex.migrate.down({\n   492→      directory: Config.MIGRATIONS_DIRECTORY,\n   493→    });\n   494→\n   495→    await Database.knex.migrate.up({\n   496→      name: `20220217012900_progress.${Config.MIGRATIONS_EXTENSION}`,\n   497→      directory: Config.MIGRATIONS_DIRECTORY,\n   498→    });\n   499→\n   500→    await Database.knex('seen').insert({\n   501→      userId: InitialData.user.id,\n   502→      mediaItemId: InitialData.mediaItem.id,\n   503→      progress: 0.1,\n   504→      duration: 123,\n   505→      date: new Date().getTime(),\n   506→      type: 'progress',\n   507→    });\n   508→  });\n   509→\n   510→  test('20220222153600_removeMetadataProviderCredentials', async () => {\n   511→    await Database.knex.migrate.up({\n   512→      name: `20220222153600_removeMetadataProviderCredentials.${Config.MIGRATIONS_EXTENSION}`,\n   513→      directory: Config.MIGRATIONS_DIRECTORY,\n   514→    });\n   515→\n   516→    await Database.knex.migrate.down({\n   517→      directory: Config.MIGRATIONS_DIRECTORY,\n   518→    });\n   519→\n   520→    await Database.knex.migrate.up({\n   521→      name: `20220222153600_removeMetadataProviderCredentials.${Config.MIGRATIONS_EXTENSION}`,\n   522→      directory: Config.MIGRATIONS_DIRECTORY,\n   523→    });\n   524→\n   525→    const { igdbClientId, igdbClientSecret } =\n   526→      (await Database.knex('configuration').first()) || {};\n   527→\n   528→    expect(igdbClientId).toEqual(InitialData.metadataProviderCredentials.value);\n   529→    expect(igdbClientSecret).toEqual(\n   530→      InitialData.metadataProviderCredentials2.value\n   531→    );\n   532→  });\n   533→\n   534→  test('20220222195700_audibleCountryCode', async () => {\n   535→    await Database.knex.migrate.up({\n   536→      name: `20220222195700_audibleCountryCode.${Config.MIGRATIONS_EXTENSION}`,\n   537→      directory: Config.MIGRATIONS_DIRECTORY,\n   538→    });\n   539→\n   540→    await Database.knex.migrate.down({\n   541→      directory: Config.MIGRATIONS_DIRECTORY,\n   542→    });\n   543→\n   544→    await Database.knex.migrate.up({\n   545→      name: `20220222195700_audibleCountryCode.${Config.MIGRATIONS_EXTENSION}`,\n   546→      directory: Config.MIGRATIONS_DIRECTORY,\n   547→    });\n   548→\n   549→    await Database.knex('mediaItem').insert({\n   550→      id: 123456,\n   551→      title: 'Title',\n   552→      source: 'audible',\n   553→      audibleCountryCode: 'uk',\n   554→    });\n   555→  });\n   556→\n   557→  test('20220310180600_userSlug', async () => {\n   558→    const user = {\n   559→      id: 1234,\n   560→      name: 'username',\n   561→      password: 'password',\n   562→      admin: false,\n   563→    };\n   564→\n   565→    const user2 = {\n   566→      id: 12345,\n   567→      name: 'username-',\n   568→      password: 'password',\n   569→      admin: false,\n   570→    };\n   571→\n   572→    await Database.knex('user').insert([user, user2]);\n   573→\n   574→    await Database.knex.migrate.up({\n   575→      name: `20220310180600_userSlug.${Config.MIGRATIONS_EXTENSION}`,\n   576→      directory: Config.MIGRATIONS_DIRECTORY,\n   577→    });\n   578→\n   579→    await Database.knex.migrate.down({\n   580→      directory: Config.MIGRATIONS_DIRECTORY,\n   581→    });\n   582→\n   583→    await Database.knex.migrate.up({\n   584→      name: `20220310180600_userSlug.${Config.MIGRATIONS_EXTENSION}`,\n   585→      directory: Config.MIGRATIONS_DIRECTORY,\n   586→    });\n   587→\n   588→    const resUser = await Database.knex('user').where('id', user.id).first();\n   589→    const resUser2 = await Database.knex('user').where('id', user2.id).first();\n   590→\n   591→    expect(toSlug(user.name)).toBe(toSlug(user2.name));\n   592→    expect(resUser.slug).not.toBe(resUser2.slug);\n   593→\n   594→    await expect(async () =>\n   595→      Database.knex('user').insert({\n   596→        name: user.name,\n   597→        password: 'password',\n   598→        admin: false,\n   599→        slug: `username-${randomSlugId()}`,\n   600→      })\n   601→    ).rejects.toMatchObject({ code: 'SQLITE_CONSTRAINT_UNIQUE' });\n   602→\n   603→    await expect(async () =>\n   604→      Database.knex('user').insert({\n   605→        name: nanoid(),\n   606→        password: 'password',\n   607→        admin: false,\n   608→        slug: resUser.slug,\n   609→      })\n   610→    ).rejects.toMatchObject({ code: 'SQLITE_CONSTRAINT_UNIQUE' });\n   611→  });\n   612→\n   613→  test('20220312002700_mediaItemSlug', async () => {\n   614→    const mediaItem = {\n   615→      id: 1234,\n   616→      title: 'title',\n   617→      source: 'user',\n   618→      mediaType: 'movie',\n   619→    };\n   620→\n   621→    const mediaItem2 = {\n   622→      id: 12345,\n   623→      title: 'title',\n   624→      source: 'user',\n   625→      mediaType: 'movie',\n   626→    };\n   627→\n   628→    await Database.knex('mediaItem').insert([mediaItem, mediaItem2]);\n   629→\n   630→    await Database.knex.migrate.up({\n   631→      name: `20220312002700_mediaItemSlug.${Config.MIGRATIONS_EXTENSION}`,\n   632→      directory: Config.MIGRATIONS_DIRECTORY,\n   633→    });\n   634→\n   635→    await Database.knex.migrate.down({\n   636→      directory: Config.MIGRATIONS_DIRECTORY,\n   637→    });\n   638→\n   639→    await Database.knex.migrate.up({\n   640→      name: `20220312002700_mediaItemSlug.${Config.MIGRATIONS_EXTENSION}`,\n   641→      directory: Config.MIGRATIONS_DIRECTORY,\n   642→    });\n   643→\n   644→    const resMediaItem = await Database.knex('mediaItem')\n   645→      .where('id', mediaItem.id)\n   646→      .first();\n   647→    const resMediaItem2 = await Database.knex('mediaItem')\n   648→      .where('id', mediaItem2.id)\n   649→      .first();\n   650→\n   651→    expect(toSlug(mediaItem.title)).toBe(toSlug(mediaItem2.title));\n   652→    expect(resMediaItem.slug).not.toBe(resMediaItem2.slug);\n   653→\n   654→    await expect(async () =>\n   655→      Database.knex('mediaIt