{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01MRwwLLxM1BgtRmr7Ty3MMk","type":"tool_result","content":"     1→export type ListPrivacy = 'public' | 'private' | 'friends';\n     2→export type ListSortOrder = 'asc' | 'desc';\n     3→export type ListSortBy =\n     4→  | 'my-rating'\n     5→  | 'recently-added'\n     6→  | 'recently-watched'\n     7→  | 'recently-aired'\n     8→  | 'next-airing'\n     9→  | 'release-date'\n    10→  | 'runtime'\n    11→  | 'title'\n    12→  | 'recommended';\n    13→\n    14→export type List = {\n    15→  id: number;\n    16→  name: string;\n    17→  description?: string;\n    18→  privacy: ListPrivacy;\n    19→  sortBy?: ListSortBy;\n    20→  sortOrder?: ListSortOrder;\n    21→  createdAt: number;\n    22→  updatedAt: number;\n    23→  userId: number;\n    24→  allowComments?: boolean;\n    25→  displayNumbers?: boolean;\n    26→  isWatchlist: boolean;\n    27→  traktId?: number;\n    28→};\n    29→\n    30→export type ListItem = {\n    31→  id: number;\n    32→  listId: number;\n    33→  mediaItemId: number;\n    34→  seasonId?: number;\n    35→  episodeId?: number;\n    36→  addedAt: number;\n    37→  estimatedRating?: number;\n    38→};\n    39→\n    40→export const listColumns = <const>[\n    41→  'id',\n    42→  'name',\n    43→  'description',\n    44→  'privacy',\n    45→  'sortBy',\n    46→  'sortOrder',\n    47→  'createdAt',\n    48→  'updatedAt',\n    49→  'userId',\n    50→];\n    51→\n    52→export const listItemColumns = <const>[\n    53→  'id',\n    54→  'listId',\n    55→  'mediaItemId',\n    56→  'seasonId',\n    57→  'episodeId',\n    58→  'estimatedRating',\n    59→];\n    60→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_012Qfg38rYA2YRJuYDHpyGvR","session_id":"c055fa73-cbc8-4bb7-a5e6-009e4e9c5990","uuid":"c67af3f1-5b02-4796-b070-8471d3cd7e36"}
