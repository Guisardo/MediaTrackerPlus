{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_bdrk_01LHxFuXV2HA8YpFzkPTkR4G","type":"tool_result","content":"     1→import { Knex } from 'knex';\n     2→import { Database } from 'src/dbconfig';\n     3→import { List, ListItem } from 'src/entity/list';\n     4→import { TvEpisode } from 'src/entity/tvepisode';\n     5→import { TvSeason } from 'src/entity/tvseason';\n     6→import { repository } from 'src/repository/repository';\n     7→\n     8→class ListItemRepository extends repository<ListItem>({\n     9→  tableName: 'listItem',\n    10→  primaryColumnName: 'id',\n    11→}) {\n    12→  async addManyItems(args: {\n    13→    userId: number;\n    14→    listId: number;\n    15→    listItems: { mediaItemId: number; seasonId?: number; episodeId?: number }[];\n    16→  }) {\n    17→    const { userId, listId, listItems } = args;\n    18→\n    19→    return await Database.knex.transaction(async (trx) => {\n    20→      const list = await trx<List>('list')\n    21→        .where({ id: listId, userId: userId })\n    22→        .first();\n    23→\n    24→      if (!list || (list.userId !== userId && list.privacy === 'private')) {\n    25→        return false;\n    26→      }\n    27→\n    28→      const existingListItems = await trx<ListItem>('listItem').where({\n    29→        listId: listId,\n    30→      });\n    31→\n    32→      const serializeListItem = (listItem: {\n    33→        mediaItemId: number;\n    34→        seasonId?: number;\n    35→        episodeId?: number;\n    36→      }) => {\n    37→        return JSON.stringify([\n    38→          listItem.mediaItemId,\n    39→          listItem.seasonId,\n    40→          listItem.episodeId,\n    41→        ]);\n    42→      };\n    43→      const existingListItemsSet = new Set(\n    44→        existingListItems.map(serializeListItem)\n    45→      );\n    46→\n    47→      const itemsToAdd = listItems\n    48→        .filter(\n    49→          (listItem) => !existingListItemsSet.has(serializeListItem(listItem))\n    50→        )\n    51→        .map((listItem) => ({\n    52→          listId: listId,\n    53→          addedAt: new Date().getTime(),\n    54→          mediaItemId: listItem.mediaItemId,\n    55→          seasonId: listItem.seasonId,\n    56→          episodeId: listItem.episodeId,\n    57→        }));\n    58→\n    59→      if (itemsToAdd.length > 0) {\n    60→        await trx.batchInsert<ListItem>('listItem', itemsToAdd, 30);\n    61→      }\n    62→\n    63→      return true;\n    64→    });\n    65→  }\n    66→\n    67→  addItem = this.#addOrRemoveListItemFactory(async (trx, args) => {\n    68→    const { mediaItemId, seasonId, episodeId, listId } = args;\n    69→\n    70→    if (mediaItemId && seasonId) {\n    71→      const season = await trx<TvSeason>('season')\n    72→        .where('tvShowId', mediaItemId)\n    73→        .where('id', seasonId)\n    74→        .first();\n    75→\n    76→      if (!season) {\n    77→        return false;\n    78→      }\n    79→    }\n    80→\n    81→    if (mediaItemId && episodeId) {\n    82→      const episode = await trx<TvEpisode>('episode')\n    83→        .where('tvShowId', mediaItemId)\n    84→        .where('id', episodeId)\n    85→        .first();\n    86→\n    87→      if (!episode) {\n    88→        return false;\n    89→      }\n    90→    }\n    91→\n    92→    const existingItems = await trx('listItem').where({\n    93→      listId: listId,\n    94→      mediaItemId: mediaItemId,\n    95→      seasonId: episodeId == undefined ? seasonId || null : null,\n    96→      episodeId: episodeId || null,\n    97→    });\n    98→\n    99→    if (existingItems.length > 0) {\n   100→      return false;\n   101→    }\n   102→\n   103→    await trx('listItem').insert({\n   104→      listId: listId,\n   105→      mediaItemId: mediaItemId,\n   106→      seasonId: episodeId == undefined ? seasonId || null : null,\n   107→      episodeId: episodeId || null,\n   108→      addedAt: new Date().getTime(),\n   109→    });\n   110→\n   111→    return true;\n   112→  });\n   113→\n   114→  removeItem = this.#addOrRemoveListItemFactory(async (trx, args) => {\n   115→    const { mediaItemId, seasonId, episodeId, listId } = args;\n   116→\n   117→    const listItem = await trx('listItem')\n   118→      .where({\n   119→        mediaItemId: mediaItemId,\n   120→        seasonId: seasonId || null,\n   121→        episodeId: episodeId || null,\n   122→        listId: listId,\n   123→      })\n   124→      .first();\n   125→\n   126→    if (listItem) {\n   127→      await trx('listItem').delete().where('id', listItem.id);\n   128→    }\n   129→\n   130→    return true;\n   131→  });\n   132→\n   133→  #addOrRemoveListItemFactory(\n   134→    fn: (\n   135→      trx: Knex.Transaction,\n   136→      args: {\n   137→        userId: number;\n   138→        mediaItemId: number;\n   139→        seasonId?: number;\n   140→        episodeId?: number;\n   141→        listId: number;\n   142→      }\n   143→    ) => Promise<boolean>\n   144→  ) {\n   145→    return async (\n   146→      args: {\n   147→        userId: number;\n   148→        mediaItemId: number;\n   149→        seasonId?: number;\n   150→        episodeId?: number;\n   151→      } & (\n   152→        | {\n   153→            watchlist: true;\n   154→          }\n   155→        | {\n   156→            listId: number;\n   157→          }\n   158→      )\n   159→    ) => {\n   160→      const { userId, listId, watchlist, mediaItemId, seasonId, episodeId } = {\n   161→        listId: undefined,\n   162→        watchlist: undefined,\n   163→        ...args,\n   164→      };\n   165→\n   166→      if (\n   167→        (listId != undefined && watchlist != undefined) ||\n   168→        (listId == undefined && watchlist == undefined)\n   169→      ) {\n   170→        throw new Error(\n   171→          'only one of listId and addToWatchlist arguments should be provided'\n   172→        );\n   173→      }\n   174→\n   175→      return await Database.knex.transaction(async (trx) => {\n   176→        const list = await trx<List>('list')\n   177→          .where(\n   178→            listId != undefined\n   179→              ? {\n   180→                  id: listId,\n   181→                }\n   182→              : {\n   183→                  isWatchlist: true,\n   184→                  userId: userId,\n   185→                }\n   186→          )\n   187→          .first();\n   188→\n   189→        if (!list || (list.userId !== userId && list.privacy === 'private')) {\n   190→          return false;\n   191→        }\n   192→\n   193→        return fn(trx, {\n   194→          mediaItemId,\n   195→          seasonId,\n   196→          episodeId,\n   197→          userId,\n   198→          listId: list.id,\n   199→        });\n   200→      });\n   201→    };\n   202→  }\n   203→}\n   204→\n   205→export const listItemRepository = new ListItemRepository();\n   206→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_bdrk_012Qfg38rYA2YRJuYDHpyGvR","session_id":"c055fa73-cbc8-4bb7-a5e6-009e4e9c5990","uuid":"d0263f1b-d4f9-491e-a6c2-90ee0feeb785"}
