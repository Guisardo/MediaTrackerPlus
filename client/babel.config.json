{
  "presets": [
    [
      "@babel/preset-env",
      {
        "useBuiltIns": "usage",
        "corejs": "3.21.0"
      }
    ],
    "@babel/preset-react",
    "@babel/preset-typescript"
  ],
  "plugins": ["@babel/plugin-transform-runtime", "@lingui/babel-plugin-lingui-macro"],
  "env": {
    "test": {
      "presets": [
        ["@babel/preset-env", {"targets": {"node": "current"}}],
        "@babel/preset-react",
        "@babel/preset-typescript"
      ]
    }
  }
}
